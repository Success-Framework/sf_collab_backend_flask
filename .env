# 1 hour = 3600 seconds

JWT_REFRESH_TOKEN_EXPIRES=2592000
# 30 days = 2592000 seconds


# Model cache location
HF_HOME=./model_cache
TRANSFORMERS_CACHE=./model_cache
TORCH_HOME=./model_cache

# Performance
TOKENIZERS_PARALLELISM=false